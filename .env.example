# Copy to .env and fill in values

# Kafka / Redpanda
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW=transactions-raw
KAFKA_TOPIC_ENRICHED=transactions-enriched
KAFKA_TOPIC_SCORED=transactions-scored
KAFKA_TOPIC_SHADOW=shadow-results
KAFKA_CONSUMER_GROUP=fraud-detection-cg

# Redis (Feast online store)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=fraud-detection
MLFLOW_MODEL_NAME=fraud-detector

# Ray Serve
RAY_SERVE_HOST=http://localhost:8000
RAY_DASHBOARD_HOST=http://localhost:8265

# Feast
FEAST_REPO_PATH=./services/feature-store/src/feature_store/repo

# MinIO / S3 (Iceberg offline store)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_ENDPOINT_URL=http://localhost:9000
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
ICEBERG_WAREHOUSE=s3://fraud-detection/iceberg

# Serving config
ONNX_MODEL_PATH=./models/registry/fraud_detector/latest/model.onnx
ONNX_SESSION_POOL_SIZE=4
ONNX_INTRA_OP_THREADS=1
ONNX_INTER_OP_THREADS=1
ONNX_PROFILE_ENABLED=false
ONNX_PROFILE_DIR=./reports/onnx_profiles
LATENCY_SLA_P95_MS=50
SERVE_SCORER_REPLICAS=2
SERVE_ROUTER_REPLICAS=2
SERVE_ROUTER_MAX_ONGOING_REQUESTS=100
SERVE_USE_ROUTER=true
SERVE_USE_QUANTIZED_MODEL=false
VERSION_MANAGER_ENABLED=true
ONLINE_UPDATES_ENABLED=true
ONLINE_UPDATE_SAMPLE_RATE=1.0
ONLINE_UPDATE_QUEUE_MAXSIZE=2048
ONLINE_UPDATE_BATCH_SIZE=64
ONLINE_UPDATE_FLUSH_INTERVAL_S=0.25
RAY_TMPDIR=~/.raytmp

# Shadow deployment
SHADOW_ENABLED=true
SHADOW_RATIO=1.0
SHADOW_TIMEOUT_S=0.1

# Monitoring
DRIFT_SHARE_THRESHOLD=0.30
TARGET_PSI_THRESHOLD=0.25
DRIFT_CHECK_INTERVAL_MINUTES=15
ALERT_WEBHOOK_URL=

# Load testing
LOAD_TEST_TARGET_RPS=10000
LOAD_TEST_DURATION_S=300
LOAD_TEST_RAMP_TIME_S=60
LOAD_TEST_STAGE1_DURATION_S=60
LOAD_TEST_STAGE1_USERS=50
LOAD_TEST_STAGE1_SPAWN_RATE=5
LOAD_TEST_STAGE2_DURATION_S=300
LOAD_TEST_STAGE2_USERS=200
LOAD_TEST_STAGE2_SPAWN_RATE=20
LOAD_TEST_STAGE3_DURATION_S=360
LOAD_TEST_STAGE3_USERS=0
LOAD_TEST_STAGE3_SPAWN_RATE=50

# Environment
ENV=local
LOG_LEVEL=INFO
